# Dependencies
node_modules/
.npm

# Environment
.env
.env.local
.env.*.local
.jm-adk.local.json

# Firebase
.firebase/
firebase-debug.log

# IDE
.idea/
.vscode/
.codex/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build
dist/
build/
.cache/
coverage/
htmlcov/
__pycache__/
*.py[cod]
.pytest_cache/

# Local overrides and experiments
.local/
*.bak
*.tmp
tmp/
temp/

# Session files (generated per-session)
.specify/context.json
.specify/score-history.json
.specify/dashboard.pid.json

# Workspace (ephemeral session state — contents not committed, dir structure preserved)
workspace/*
!workspace/.gitkeep

# User context repo (scaffold tracked inside user-context/.gitignore; private content ignored there)
user-context/manifest.json
user-context/context/*
!user-context/context/README.md
!user-context/context/.gitkeep
user-context/preferences/*
!user-context/preferences/README.md
!user-context/preferences/.gitkeep
user-context/memory/*
!user-context/memory/README.md
!user-context/memory/.gitkeep
user-context/sources/*
!user-context/sources/README.md
!user-context/sources/.gitkeep

# SDD sentinel state
.specify/sentinel-state.json
.specify/session-log.json

# Logs
*.log
