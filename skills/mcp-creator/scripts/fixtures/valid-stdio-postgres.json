{
  "schema": "jm-labs.mcp-creator.plan.v1",
  "skill": "mcp-creator",
  "server": {
    "name": "postgres-local",
    "name_collision_checked": true,
    "description": "Local PostgreSQL MCP server"
  },
  "transport": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL}"]
  },
  "scope": {
    "type": "local",
    "config_path": "~/.claude.json",
    "tracked_file": false,
    "rationale": "Personal local database access should not be committed."
  },
  "auth": {
    "type": "env",
    "env_vars": ["DATABASE_URL"],
    "secrets_hardcoded": false
  },
  "preflight": {
    "existing_config_reviewed": true,
    "live_validation_deferred": true,
    "deferred_reason": "No apply approval yet"
  },
  "rollback": {
    "remove_command": "claude mcp remove postgres-local",
    "config_backup_required": true
  },
  "evidence": [
    {
      "claim": "The stdio config uses DATABASE_URL as an env placeholder.",
      "evidence_tag": "[DOC]",
      "source": "secret policy"
    }
  ],
  "validation": {
    "status": "pass",
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "checks": [
      "assets",
      "deterministic_scripts",
      "quality_criteria",
      "transport_policy",
      "scope_policy",
      "secret_policy",
      "preflight_required",
      "rollback_plan",
      "evidence_required"
    ]
  }
}
