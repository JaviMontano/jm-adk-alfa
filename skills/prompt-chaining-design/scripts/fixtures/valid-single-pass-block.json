{
  "schema": 1,
  "skill": "prompt-chaining-design",
  "chain_id": "valid-single-pass-block",
  "single_pass_assessment": {
    "use_chain": false,
    "justification_reasons": ["attention_quality"]
  },
  "unit_contract": {
    "atomic_unit": "small_file_pair",
    "one_unit_per_local_pass": true,
    "idempotent": true,
    "parallelizable": true
  },
  "local_pass_schema": {
    "fields": ["unit_id", "status", "findings", "error_detail"],
    "status_values": ["ok", "error"],
    "throws_global_exception": false
  },
  "transition_schema": {
    "fields": ["summaries", "schema_version", "unit_count", "error_count"],
    "forbidden_payloads": ["raw_content", "raw_diff", "full_document"]
  },
  "integration_pass": {
    "consumes_summaries_only": true,
    "raw_units_forbidden": true,
    "handles_error_summaries": true,
    "does_not_abort_on_unit_error": true
  },
  "error_handling": {
    "typed_per_unit": true,
    "propagates_as_data": true,
    "aborts_batch": false
  },
  "validation": {
    "chain_justified": false,
    "local_pass_one_unit": true,
    "local_schema_typed": true,
    "transition_schema_present": true,
    "integration_uses_summaries_only": true,
    "typed_error_state": true,
    "deterministic_script_passed": true
  },
  "guardian": {
    "decision": "block",
    "reason": "The task fits single-pass, so prompt chaining should not be activated."
  }
}
