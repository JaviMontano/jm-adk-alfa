    {"from": "quality-dimension", "to": "reduced-scope-note", "relation": "requires_when_na"},
    {"from": "score-math", "to": "guardian-decision", "relation": "validates"},
    {"from": "priority-action", "to": "guardian-decision", "relation": "validates"}
