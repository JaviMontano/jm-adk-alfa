              "paragraphStyle": {
                "namedStyleType": "HEADING_1"
              },
              "fields": "namedStyleType"
            }
          },
          {
            "type": "createParagraphBullets",
            "payload": {
              "range": {
                "startIndex": 30,
                "endIndex": 96
