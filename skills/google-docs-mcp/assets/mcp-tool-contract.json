      "actions": [
        "get_document"
      ],
      "read_only": true,
      "requires_human_confirmation": false
    },
    {
      "name": "mcp__workspace-mcp__get_doc_as_markdown",
      "actions": [
        "get_document"
      ],
      "read_only": true,
      "requires_human_confirmation": false
    },
    {
      "name": "mcp__workspace-mcp__export_doc_to_pdf",
      "actions": [
        "get_document"
      ],
      "read_only": true,
      "requires_human_confirmation": false
    },
    {
      "name": "mcp__workspace-mcp__create_doc",
      "actions": [
        "create_document"
      ],
      "read_only": false,
      "requires_human_confirmation": true
    },
    {
      "name": "mcp__workspace-mcp__modify_doc_text",
