    "scope",
    "findings",
    "positive_patterns",
    "validation",
    "decision",
    "risks_and_limits"
  ],
  "scope_fields": [
    "review_type",
    "sources_reviewed",
    "minimum_inputs_missing",
    "depth"
  ],
  "finding_fields": [
