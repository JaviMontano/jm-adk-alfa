{
  "schema": 1,
  "skill": "subagent-orchestration",
  "coordinator": {
    "id": "company-enrichment-hub",
    "fanout_justification": "Company enrichment decomposes into independent finder, extractor, and ranker spokes with separate tool and model needs.",
    "consumes_last_message_only": true,
    "reads_spoke_transcript": false
  },
  "spokes": [
    {
      "id": "finder",
      "task": "Find the best supplied or searchable company site candidate.",
      "agent_definition": {
        "description": "Finds candidate company sites.",
        "prompt": "Return one candidate site or typed access failure.",
        "tools": ["WebFetch"],
        "model": "haiku",
        "model_role": "extraction"
      },
      "dispatch": {"tool": "Task"},
      "isolation": {"mode": "fresh_session", "shared_context": false, "shared_mutable_state": false}
    },
    {
      "id": "extractor",
      "task": "Extract sector and headcount evidence from one site.",
      "agent_definition": {
        "description": "Extracts structured facts from one site.",
        "prompt": "Return sector, headcount, valid_empty, or typed failure.",
        "tools": ["Read"],
        "model": "haiku",
        "model_role": "extraction"
      },
      "dispatch": {"tool": "Task"},
      "isolation": {"mode": "fresh_session", "shared_context": false, "shared_mutable_state": false}
    },
    {
      "id": "ranker",
      "task": "Rank enriched records after partial results and gaps are aggregated.",
      "agent_definition": {
        "description": "Ranks aggregated enrichment results.",
        "prompt": "Use only aggregate rows and coverage gaps.",
        "tools": [],
        "model": "sonnet",
        "model_role": "aggregation"
      },
      "dispatch": {"tool": "Task"},
      "isolation": {"mode": "fresh_session", "shared_context": false, "shared_mutable_state": false}
    }
  ],
  "failure_contract": {
    "required_fields": ["failure_type", "attempted_query", "partial_results", "suggested_alternatives"],
    "failure_types": ["access_failure", "rate_limited", "parse_failure"],
    "valid_empty": {"status": "ok", "empty_valid": true},
    "local_recovery": {"max_attempts": 2, "strategies": ["alternate_query", "degrade_to_partial"]}
  },
  "aggregation": {
    "partial_failure_policy": "continue_with_coverage_gap",
    "distinguish_access_failure_from_valid_empty": true,
    "coverage_gap_fields": ["spoke_id", "reason", "attempted_query"],
    "abort_on_first_failure": false,
    "empty_success_on_failure": false
  },
  "validation": {
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "result": "pass"
  }
}
