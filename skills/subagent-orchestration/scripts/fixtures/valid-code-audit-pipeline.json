{
  "schema": 1,
  "skill": "subagent-orchestration",
  "coordinator": {
    "id": "code-audit-hub",
    "fanout_justification": "Per-file review spokes are independent, reduce prompt dilution, and can fail without hiding other file findings.",
    "consumes_last_message_only": true,
    "reads_spoke_transcript": false
  },
  "spokes": [
    {
      "id": "file-reviewer",
      "task": "Review one file for findings with line evidence.",
      "agent_definition": {
        "description": "Reviews one file in a fresh session.",
        "prompt": "Return findings, valid_empty when no findings, or typed failure.",
        "tools": ["Read", "Grep"],
        "model": "haiku",
        "model_role": "verification"
      },
      "dispatch": {"tool": "Task"},
      "isolation": {"mode": "fresh_session", "shared_context": false, "shared_mutable_state": false}
    },
    {
      "id": "cross-file-synthesizer",
      "task": "Synthesize final report from file results and coverage gaps.",
      "agent_definition": {
        "description": "Aggregates reviewed file outputs only.",
        "prompt": "Use last messages, not raw spoke transcripts.",
        "tools": [],
        "model": "sonnet",
        "model_role": "aggregation"
      },
      "dispatch": {"tool": "Task"},
      "isolation": {"mode": "fresh_session", "shared_context": false, "shared_mutable_state": false}
    }
  ],
  "failure_contract": {
    "required_fields": ["failure_type", "attempted_query", "partial_results", "suggested_alternatives"],
    "failure_types": ["access_failure", "permission_denied", "parse_failure"],
    "valid_empty": {"status": "ok", "empty_valid": true},
    "local_recovery": {"max_attempts": 1, "strategies": ["alternate_path", "degrade_to_partial"]}
  },
  "aggregation": {
    "partial_failure_policy": "continue_with_coverage_gap",
    "distinguish_access_failure_from_valid_empty": true,
    "coverage_gap_fields": ["spoke_id", "reason", "attempted_query"],
    "abort_on_first_failure": false,
    "empty_success_on_failure": false
  },
  "validation": {
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "result": "pass"
  }
}
