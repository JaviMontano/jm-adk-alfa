{
  "skill": "x-ray-skill",
  "version": "1.0.0-dod",
  "assets": [
    {
      "path": "assets/README.md",
      "type": "documentation",
      "purpose": "Explains the X-Ray deterministic asset bundle.",
      "used_by": [
        "SKILL.md",
        "scripts/check.sh"
      ]
    },
    {
      "path": "assets/manifest.json",
      "type": "asset-index",
      "purpose": "Declares assets so DoD validators can verify the bundle.",
      "used_by": [
        "scripts/check.sh"
      ]
    },
    {
      "path": "assets/rubric-policy.json",
      "type": "policy",
      "purpose": "Defines rubric dimensions, thresholds, and certification formula.",
      "used_by": [
        "scripts/compile-x-ray-report.py",
        "scripts/check.sh"
      ]
    },
    {
      "path": "assets/gate-policy.json",
      "type": "policy",
      "purpose": "Defines the 13-point validation gate and component classification rules.",
      "used_by": [
        "scripts/compile-x-ray-report.py",
        "scripts/check.sh"
      ]
    },
    {
      "path": "assets/report-template.md",
      "type": "template",
      "purpose": "Documents the stable report sections generated by the compiler.",
      "used_by": [
        "scripts/compile-x-ray-report.py",
        "templates/output.md"
      ]
    }
  ]
}
