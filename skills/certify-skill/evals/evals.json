{
  "schema": 1,
  "skill": "certify-skill",
  "cases": [
    {
      "id": "moat-golden-path",
      "name": "MOAT golden path",
      "type": "happy_path",
      "input": "Certify a fully complete multi-file skill with all structural, content, systemic, rubric, and MOAT checks passing.",
      "fixture": "scripts/fixtures/moat-report.json",
      "expected_activation": true,
      "expected_certification": "MOAT",
      "expected_outputs": ["summary", "rubric_scores", "structural_checks", "moat_checks", "recommendation"],
      "forbidden_outputs": ["probably certified", "skip evidence"],
      "expected_checks": ["assets", "deterministic_scripts", "quality_criteria", "activation_policy", "report_schema", "certification_formula", "rubric_scores", "structural_checks", "moat_checks", "evidence_tags"]
    },
    {
      "id": "certified-not-moat",
      "name": "Certified but not MOAT",
      "type": "happy_path",
      "input": "Certify a skill that passes phases 1-4 but fails one MOAT upgrade check.",
      "expected_activation": true,
      "expected_certification": "CERTIFIED",
      "expected_outputs": ["upgrade note", "MOAT missing check", "no blockers"],
      "forbidden_outputs": ["MOAT", "blocked"],
      "expected_checks": ["assets", "deterministic_scripts", "quality_criteria", "certification_formula", "moat_checks", "report_schema"]
    },
    {
      "id": "conditional-one-structural-fail",
      "name": "Conditional structural failure",
      "type": "edge_case",
      "input": "Certify a skill with one non-S1 structural failure and rubric average 8.0.",
      "fixture": "scripts/fixtures/conditional-report.json",
      "expected_activation": true,
      "expected_certification": "CONDITIONAL",
      "expected_outputs": ["blockers", "fix_required", "estimated_effort"],
      "forbidden_outputs": ["ship it", "CERTIFIED"],
      "expected_checks": ["assets", "deterministic_scripts", "quality_criteria", "structural_checks", "certification_formula", "blocker_rows", "evidence_tags"]
    },
    {
      "id": "conditional-one-rubric-six",
      "name": "Conditional rubric six",
      "type": "edge_case",
      "input": "Certify a skill with one rubric dimension scored 6 and average >= 8.0.",
      "expected_activation": true,
      "expected_certification": "CONDITIONAL",
      "expected_outputs": ["score < 7 fix", "conditional recommendation"],
      "forbidden_outputs": ["CERTIFIED"],
      "expected_checks": ["assets", "deterministic_scripts", "quality_criteria", "rubric_scores", "certification_formula", "blocker_rows"]
    },
    {
