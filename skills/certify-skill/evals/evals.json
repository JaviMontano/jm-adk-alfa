      "forbidden_outputs": ["CONDITIONAL", "CERTIFIED"],
      "expected_checks": ["assets", "deterministic_scripts", "quality_criteria", "structural_checks", "certification_formula", "blocking_policy"]
    },
    {
      "id": "blocked-invalid-frontmatter",
      "name": "Blocked invalid frontmatter",
      "type": "negative",
      "input": "Certify a skill whose YAML frontmatter cannot parse.",
