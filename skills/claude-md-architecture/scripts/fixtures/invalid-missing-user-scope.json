{
  "repo": "bad-repo",
  "root": {
    "path": "CLAUDE.md",
    "lineCount": 120,
    "imports": [
      {
        "target": "./frontend/CLAUDE.md",
        "scope": "module",
        "stable": true
      }
    ],
    "universalRules": [
      "Use conventional commits."
    ],
    "pathScopedImports": [
      {
        "glob": "frontend/**",
        "target": "./frontend/CLAUDE.md",
        "reason": "Frontend rules."
      }
    ]
  },
  "modules": [
    {
      "name": "frontend",
      "path": "frontend",
      "glob": "frontend/**",
      "claudeMd": "frontend/CLAUDE.md",
      "rules": [
        "Use design-system tokens."
      ]
    }
  ],
  "userScope": {
    "path": "CLAUDE.local.md",
    "preferences": [
      "Prefer pnpm."
    ],
    "versionedInRepo": true
  },
  "precedence": {
    "mode": "most_specific_subpath_wins",
    "levels": [
      "user",
      "team",
      "module"
    ],
    "conflictResolution": "Module rules refine team rules."
  },
  "cachePolicy": {
    "stablePrefix": true,
    "noTurnSpecificValues": true,
    "rootOnlyUniversalRules": true
  },
  "validation": {
    "separatedScopes": true,
    "pathScopedRules": true,
    "personalPrefsOutOfRepo": true,
    "mostSpecificWins": true
  },
  "risks": [
    "User preference location is wrong."
  ]
}
