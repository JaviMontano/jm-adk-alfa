{
  "schema": 1,
  "required_root_fields": [
    "system_name",
    "audience",
    "business_goal",
    "scope",
    "deployment_preference",
    "data_sensitivity",
    "knowledge_base",
    "knowledge_sources",
    "rag_pipeline",
    "use_cases",
    "model_tiers",
    "connectors",
    "quality_targets",
    "evidence"
