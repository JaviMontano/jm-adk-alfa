{
  "schema": 1,
  "skill": "tool-use-design",
  "tool_contracts": [
    {
      "name": "search_code",
      "purpose": "Find files or symbols by pattern across the repository.",
      "input_format": "regex_or_literal string",
      "examples": ["search_code(pattern='def handle_payment')"],
      "boundary": {
        "use_for": "Locate candidate files and symbols.",
        "not_for": "Reading full file contents or applying edits.",
        "delegate_to": ["read_file"]
      }
    },
    {
      "name": "read_file",
      "purpose": "Read the full contents of one known file path.",
      "input_format": "absolute_path string",
      "examples": ["read_file(path='/repo/app.py')"],
      "boundary": {
        "use_for": "Inspect a file after search_code located it.",
        "not_for": "Discovering files or replacing text.",
        "delegate_to": ["search_code", "edit_file"]
      }
    },
    {
      "name": "edit_file",
      "purpose": "Replace a unique anchor string in one known file.",
      "input_format": "path, old_string, new_string",
      "examples": ["edit_file(path='/repo/app.py', old_string='old', new_string='new')"],
      "boundary": {
        "use_for": "Apply a precise replacement after reading the file.",
        "not_for": "Discovery or full-file inspection.",
        "delegate_to": ["read_file"]
      }
    }
  ],
  "overload_resolution": {
    "decision": "rename_split",
    "resolved_by_prose": false,
    "split_tools": ["search_code", "read_file", "edit_file"]
  },
  "repo_strategy": {
    "sequence": ["grep", "read", "edit"],
    "read_all_upfront": false,
    "glob_all_then_read_all": false
  },
  "edit_safety": {
    "unique_anchor_required": true,
    "failure_mode": "non_unique_anchor",
    "fallback": "read_write_full_rewrite"
  },
  "validation": {
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "result": "pass"
  }
}
