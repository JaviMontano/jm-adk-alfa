{
  "schema": 1,
  "skill": "tool-use-design",
  "tool_contracts": [
    {
      "name": "manage_file",
      "purpose": "Search, read, and edit files depending on the situation.",
      "input_format": "mixed object",
      "examples": ["manage_file({'query':'x'})"],
      "boundary": {
        "use_for": "Do all file operations.",
        "not_for": "Nothing.",
        "delegate_to": ["manage_repo"]
      }
    },
    {
      "name": "manage_repo",
      "purpose": "Manage repository context.",
      "input_format": "mixed object",
      "examples": ["manage_repo({'path':'/repo'})"],
      "boundary": {
        "use_for": "Broad repo operations.",
        "not_for": "Specific file operations.",
        "delegate_to": ["manage_file"]
      }
    }
  ],
  "overload_resolution": {
    "decision": "describe_in_prose",
    "resolved_by_prose": true,
    "split_tools": ["manage_file"]
  },
  "repo_strategy": {
    "sequence": ["grep", "read", "edit"],
    "read_all_upfront": false,
    "glob_all_then_read_all": false
  },
  "edit_safety": {
    "unique_anchor_required": true,
    "failure_mode": "non_unique_anchor",
    "fallback": "read_write_full_rewrite"
  },
  "validation": {
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "result": "pass"
  }
}
