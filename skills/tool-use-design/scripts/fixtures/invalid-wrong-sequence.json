{
  "schema": 1,
  "skill": "tool-use-design",
  "tool_contracts": [
    {
      "name": "read_file",
      "purpose": "Read one known file.",
      "input_format": "path",
      "examples": ["read_file('/repo/a.py')"],
      "boundary": {
        "use_for": "Read file.",
        "not_for": "Search.",
        "delegate_to": ["search_code"]
      }
    },
    {
      "name": "search_code",
      "purpose": "Find files.",
      "input_format": "pattern",
      "examples": ["search_code('x')"],
      "boundary": {
        "use_for": "Search files.",
        "not_for": "Read files.",
        "delegate_to": ["read_file"]
      }
    }
  ],
  "overload_resolution": {
    "decision": "rename_split",
    "resolved_by_prose": false,
    "split_tools": ["search_code", "read_file"]
  },
  "repo_strategy": {
    "sequence": ["read", "grep", "edit"],
    "read_all_upfront": false,
    "glob_all_then_read_all": false
  },
  "edit_safety": {
    "unique_anchor_required": true,
    "failure_mode": "non_unique_anchor",
    "fallback": "read_write_full_rewrite"
  },
  "validation": {
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "result": "pass"
  }
}
