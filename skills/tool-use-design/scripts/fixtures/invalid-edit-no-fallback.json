{
  "schema": 1,
  "skill": "tool-use-design",
  "tool_contracts": [
    {
      "name": "read_file",
      "purpose": "Read one known file.",
      "input_format": "path",
      "examples": ["read_file('/repo/a.py')"],
      "boundary": {
        "use_for": "Read file.",
        "not_for": "Edit file.",
        "delegate_to": ["edit_file"]
      }
    },
    {
      "name": "edit_file",
      "purpose": "Edit one known file.",
      "input_format": "path and replacement",
      "examples": ["edit_file('/repo/a.py')"],
      "boundary": {
        "use_for": "Edit file.",
        "not_for": "Read file.",
        "delegate_to": ["read_file"]
      }
    }
  ],
  "overload_resolution": {
    "decision": "rename_split",
    "resolved_by_prose": false,
    "split_tools": ["read_file", "edit_file"]
  },
  "repo_strategy": {
    "sequence": ["grep", "read", "edit"],
    "read_all_upfront": false,
    "glob_all_then_read_all": false
  },
  "edit_safety": {
    "unique_anchor_required": false,
    "failure_mode": "unknown",
    "fallback": ""
  },
  "validation": {
    "offline": true,
    "network_required": false,
    "deterministic": true,
    "result": "pass"
  }
}
