{
  "skill": "error-recovery-automation",
  "schema": 1,
  "nodes": [
    {
      "id": "failure-evidence",
      "type": "input",
      "description": "Observed command, exit code, error excerpt, state impact, and last safe checkpoint."
    },
    {
      "id": "error-classification",
      "type": "decision",
      "description": "Mapping from observed failure to category and recoverability."
    },
    {
      "id": "bounded-retry",
      "type": "control",
      "description": "Deterministic retry policy with attempts, backoff, idempotency, and stop conditions."
    },
    {
      "id": "rollback-plan",
      "type": "control",
      "description": "State protection plan with rollback steps and verification."
    },
    {
      "id": "escalation-handoff",
      "type": "handoff",
      "description": "Owner, trigger, evidence bundle, and requested decision for non-retryable failures."
    },
    {
      "id": "validation-evidence",
      "type": "output",
      "description": "Pre-retry and post-recovery checks proving the outcome."
    }
  ],
  "edges": [
    {"from": "failure-evidence", "to": "error-classification", "relation": "supports"},
    {"from": "error-classification", "to": "bounded-retry", "relation": "permits_when_retryable"},
    {"from": "error-classification", "to": "rollback-plan", "relation": "requires_when_stateful"},
    {"from": "error-classification", "to": "escalation-handoff", "relation": "requires_when_not_retryable"},
    {"from": "bounded-retry", "to": "validation-evidence", "relation": "must_produce"},
    {"from": "rollback-plan", "to": "validation-evidence", "relation": "must_verify"}
  ]
}
