{
  "skill": "health-check-automation",
  "schema": 1,
  "nodes": [
    {
      "id": "health-surface",
      "type": "input",
      "description": "Services, dependencies, resources, jobs, and alert routes in scope."
    },
    {
      "id": "captured-evidence",
      "type": "input",
      "description": "Snapshot metadata, observed values, command output, and source labels."
    },
    {
      "id": "deterministic-check",
      "type": "control",
      "description": "Named check with required flag, status, threshold, and evidence source."
    },
    {
      "id": "status-classification",
      "type": "decision",
      "description": "Check-level pass, warn, fail, or unknown result."
    },
    {
      "id": "alert-routing",
      "type": "handoff",
      "description": "Severity, owner, trigger, and handoff evidence for warn or fail outcomes."
    },
    {
      "id": "degradation-plan",
      "type": "control",
      "description": "Behavior when required checks fail, warn, or cannot be verified."
    },
    {
      "id": "guardian-decision",
      "type": "output",
      "description": "Overall healthy, degraded, unhealthy, or blocked decision."
    }
  ],
  "edges": [
    {"from": "health-surface", "to": "deterministic-check", "relation": "defines_scope"},
    {"from": "captured-evidence", "to": "deterministic-check", "relation": "supports"},
    {"from": "deterministic-check", "to": "status-classification", "relation": "produces"},
    {"from": "status-classification", "to": "alert-routing", "relation": "triggers"},
    {"from": "status-classification", "to": "degradation-plan", "relation": "requires_when_not_pass"},
    {"from": "status-classification", "to": "guardian-decision", "relation": "rolls_up_to"}
  ]
}
