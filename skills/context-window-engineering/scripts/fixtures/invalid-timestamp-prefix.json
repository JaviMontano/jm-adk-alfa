{
  "application": "bad-prefix",
  "contextWindow": {
    "maxTokens": 200000,
    "expectedSteadyStateTokens": 100000
  },
  "staticPrefix": {
    "blocks": [
      {
        "id": "header",
        "kind": "policy",
        "content": "Current time: {timestamp}",
        "stable": true
      }
    ]
  },
  "middle": {
    "compactable": true,
    "blocks": [
      {
        "id": "history",
        "kind": "history",
        "content": "Long history.",
        "stable": false
      }
    ]
  },
  "dynamicTail": {
    "position": "final",
    "blocks": [
      {
        "id": "reminder",
        "kind": "reminder",
        "content": "Final reminder.",
        "stable": false,
        "volatileFields": [
          "turn_state"
        ]
      }
    ]
  },
  "criticalRules": [
    {
      "id": "rule",
      "text": "Do not close tickets without confirmation.",
      "placements": [
        "static_prefix",
        "dynamic_tail"
      ]
    }
  ],
  "compaction": {
    "enabled": true,
    "threshold": 0.55,
    "preserveBlockIds": [
      "header",
      "reminder"
    ],
    "summarizeBlockKinds": [
      "history"
    ]
  },
  "validation": {
    "prefixByteIdentical": true,
    "noVolatileInPrefix": true,
    "dynamicOnlyInReminder": true,
    "criticalRulesAtEdges": true,
    "compactionPreservesEdges": true,
    "cacheHitMeasuredOrEstimated": true,
    "retentionTestDefined": true
  },
  "risks": [
    "Invalid fixture should fail."
  ]
}
