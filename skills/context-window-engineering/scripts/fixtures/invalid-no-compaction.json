{
  "application": "no-compaction",
  "contextWindow": {
    "maxTokens": 128000,
    "expectedSteadyStateTokens": 90000
  },
  "staticPrefix": {
    "blocks": [
      {
        "id": "role",
        "kind": "role",
        "content": "Stable role.",
        "stable": true
      }
    ]
  },
  "middle": {
    "compactable": true,
    "blocks": [
      {
        "id": "history",
        "kind": "history",
        "content": "Long history.",
        "stable": false
      }
    ]
  },
  "dynamicTail": {
    "position": "final",
    "blocks": [
      {
        "id": "reminder",
        "kind": "reminder",
        "content": "Final reminder.",
        "stable": false,
        "volatileFields": [
          "latest_message"
        ]
      }
    ]
  },
  "criticalRules": [
    {
      "id": "rule",
      "text": "Do not delete files without confirmation.",
      "placements": [
        "static_prefix",
        "dynamic_tail"
      ]
    }
  ],
  "compaction": {
    "enabled": false,
    "threshold": 0.25,
    "preserveBlockIds": [
      "role",
      "reminder"
    ],
    "summarizeBlockKinds": [
      "history"
    ]
  },
  "validation": {
    "prefixByteIdentical": true,
    "noVolatileInPrefix": true,
    "dynamicOnlyInReminder": true,
    "criticalRulesAtEdges": true,
    "compactionPreservesEdges": true,
    "cacheHitMeasuredOrEstimated": true,
    "retentionTestDefined": true
  },
  "risks": [
    "Invalid fixture should fail."
  ]
}
