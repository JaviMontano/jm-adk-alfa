{
  "schema": 1,
  "plan_schema": "google-apis-integration-plan/v1",
  "required_root_fields": [
    "schema_version",
    "project",
    "integration_mode",
    "services",
    "human_consent",
    "secrets",
    "test_matrix",
    "evidence"
  ],
  "required_project_fields": [
    "name",
    "owner",
    "environment"
  ],
  "required_service_fields": [
    "id",
    "operation",
    "purpose",
    "auth_profile",
    "requested_scopes",
    "mutation",
    "resource_identifiers",
    "read_before_write",
    "idempotency_key",
    "retry_policy",
    "quota_strategy"
  ],
  "required_quota_strategy_fields": [
    "batching",
    "partial_response_fields",
    "quota_user_or_key_restriction"
  ],
  "required_human_consent_fields": [
    "status",
    "confirmed_by",
    "confirmation_text"
  ],
  "required_secret_fields": [
    "token_storage",
    "client_secret_exposure",
    "refresh_tokens_encrypted",
    "api_keys_restricted",
    "oauth_tokens_server_side",
    "no_static_secrets_in_client",
    "maps_api_key_restriction"
  ],
  "idempotency_key_pattern": "^[a-z0-9][a-z0-9-]{5,100}$",
  "supported_integration_modes": [
    "multi_service_backend",
    "web_app_with_backend",
    "serverless_backend"
  ],
  "mutating_services_require": [
    "human_consent.status=confirmed",
    "read_before_write=true",
    "idempotency_key",
    "retry_policy"
  ]
}
