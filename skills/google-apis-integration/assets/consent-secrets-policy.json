{
  "schema": 1,
  "human_consent": {
    "required_for_mutations": true,
    "accepted_status": "confirmed",
    "confirmation_text_prefix": "I approve Google API mutations:",
    "must_cover": [
      "service",
      "operation",
      "resource",
      "scope",
      "side_effect",
      "notification_or_publication"
    ]
  },
  "secrets": {
    "allowed_token_storage": [
      "server_secret_manager",
      "encrypted_server_store",
      "runtime_env_injection"
    ],
    "required_true": [
      "refresh_tokens_encrypted",
      "api_keys_restricted",
      "oauth_tokens_server_side",
      "no_static_secrets_in_client"
    ],
    "client_secret_exposure": "never",
    "maps_api_key_restriction": "http_referrer_and_api_restricted",
    "forbidden_locations": [
      "source_control",
      "static_html",
      "browser_local_storage",
      "public_fixture",
      "logs"
    ]
  }
}
