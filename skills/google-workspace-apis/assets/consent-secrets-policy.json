{
  "schema": 1,
  "human_consent": {
    "accepted_status": "confirmed",
    "confirmation_text_prefix": "I approve Workspace API mutations:",
    "required_for": [
      "Gmail send or label mutation",
      "Calendar create, patch, delete, or invitation send",
      "Drive create, update, delete, or permission change",
      "Docs, Sheets, or Slides batchUpdate",
      "Any MCP tool with requires_human_confirmation=true"
    ]
  },
  "secrets": {
    "allowed_token_storage": ["server_secret_manager", "encrypted_database", "local_dev_keychain"],
    "client_secret_exposure": "never",
    "required_true": [
      "refresh_tokens_encrypted",
      "oauth_tokens_server_side",
      "no_static_secrets_in_client",
      "no_service_account_key_in_repo",
      "log_redaction_enabled"
    ],
    "forbidden_locations": [
      "source_repository",
      "static_frontend_bundle",
      "public_issue_tracker",
      "plain_text_logs"
    ]
  }
}
