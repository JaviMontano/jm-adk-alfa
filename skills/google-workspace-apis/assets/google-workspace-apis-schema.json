{
  "schema": 1,
  "required_root_fields": [
    "schema_version",
    "project",
    "integration_mode",
    "services",
    "workflow",
    "human_consent",
    "secrets",
    "test_matrix",
    "evidence"
  ],
  "required_project_fields": ["name", "owner", "environment", "objective"],
  "supported_integration_modes": ["rest", "mcp", "rest-and-mcp"],
  "required_service_fields": [
    "id",
    "operation",
    "purpose",
    "mutation",
    "auth_profile",
    "requested_scopes",
    "mcp_tool",
    "read_before_write",
    "resource_identifiers",
    "quota_strategy"
  ],
  "required_quota_strategy_fields": ["batching", "partial_response_fields", "retry_policy"],
  "required_workflow_fields": ["read_only_first", "cross_service_steps", "rollback_plan"],
  "required_human_consent_fields": ["status", "confirmed_by", "confirmation_text"],
  "required_secret_fields": ["credential_storage", "tokens_committed", "api_keys_restricted"],
  "idempotency_key_pattern": "^[a-z0-9][a-z0-9-]{4,80}$"
}
