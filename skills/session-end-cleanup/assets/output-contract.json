{
  "schema": 1,
  "skill": "session-end-cleanup",
  "markdown_sections": [
    "Session Summary",
    "Changes Completed",
    "Decisions And Assumptions",
    "Open Tasks",
    "Insights Captured",
    "Risks And Blockers",
    "Validation Evidence",
    "Durable Updates",
    "Next Handoff",
    "Guardian Decision"
  ],
  "json_required_keys": [
    "schema_version",
    "skill",
    "session",
    "summary",
    "changes_completed",
    "decisions",
    "open_tasks",
    "insights",
    "risks",
    "validation",
    "durable_updates",
    "next_handoff",
    "guardian_decision"
  ],
  "allowed_task_statuses": ["done", "open", "blocked", "proposed"],
  "allowed_validation_statuses": ["pass", "fail", "skipped", "unknown"],
  "allowed_guardian_decisions": ["pass", "block"],
  "completion_rule": "A task with status done must include completion_evidence and an allowed evidence_tag other than [ASSUMPTION] or [OPEN].",
  "validation_rule": "Every validation entry must include command, status, and evidence_tag. A pass guardian decision requires at least one validation entry."
}
