{
  "schema": 1,
  "compiler_mode": "offline_only",
  "read_only_first": {
    "required_for_mutations": true,
    "first_action_types": [
      "spreadsheets.get",
      "spreadsheets.values.get"
    ],
    "required_fields": [
      "enabled",
      "metadata_checked",
      "ranges_checked",
      "formula_impact_checked",
      "protected_ranges_reviewed"
    ]
  },
  "human_confirmation": {
    "required_for": [
      "spreadsheets.create",
      "spreadsheets.batchUpdate",
      "spreadsheets.values.update",
      "spreadsheets.values.append",
      "spreadsheets.values.batchUpdate"
    ],
    "required_status": "confirmed",
    "confirmation_phrase_prefix": "CONFIRM_SHEETS_MUTATION"
  },
  "live_execution_policy": {
    "default": "plan_only",
    "requires_separate_review": true,
    "blocked_without_confirmation": true
  }
}
